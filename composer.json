{
    "name": "medcore-ua/ukrainian-anthroponyms",
    "description": "PHP library for declension of Ukrainian anthroponyms",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "MedCore\\UkrainianAnthroponyms\\": "src/"
        },
        "files": [
            "src/WordDeclension/InflectionCommand.php",
            "src/WordDeclension/DeclensionRule.php",
            "src/WordDeclension/DeclensionPattern.php",
            "src/WordDeclension/GrammaticalCases.php",
            "src/WordDeclension/InflectionCommandRunnerInterface.php",
            "src/WordDeclension/CommandRunners.php"
        ]
    },
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "suggest": {
        "ext-mbstring": "For proper Unicode handling"
    }
}